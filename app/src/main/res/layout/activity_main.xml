<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/main_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_screen_atmosphere"
    android:clipChildren="false"
    android:clipToPadding="false"
    android:paddingLeft="@dimen/home_page_side_margin"
    android:paddingRight="@dimen/home_page_side_margin">

    <ImageView
        android:id="@+id/iv_main_background"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginStart="-12dp"
        android:layout_marginEnd="-12dp"
        android:contentDescription="@null"
        android:scaleType="centerCrop"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <FrameLayout
        android:id="@+id/card_pet_stage"
        android:layout_width="@dimen/home_stage_width"
        android:layout_height="@dimen/home_stage_height"
        android:background="@drawable/bg_home_pet_stage"
        android:clipToOutline="true"
        android:elevation="1dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <ImageView
            android:id="@+id/iv_pet_avatar"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:contentDescription="@string/home_cd_pet_avatar"
            android:scaleType="fitCenter" />

        <TextView
            android:id="@+id/tv_pet_avatar_placeholder"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:background="@drawable/bg_home_meta_chip"
            android:paddingLeft="12dp"
            android:paddingTop="6dp"
            android:paddingRight="12dp"
            android:paddingBottom="6dp"
            android:text="@string/home_pet_avatar_placeholder_hint"
            android:textColor="@android:color/white"
            android:textSize="12sp"
            android:visibility="gone" />

    </FrameLayout>

    <LinearLayout
        android:id="@+id/layout_top_info"
        android:layout_width="0dp"
        android:layout_height="@dimen/home_top_bar_height"
        android:elevation="20dp"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <TextView
            android:id="@+id/tv_time"
            android:layout_width="110dp"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_home_info_chip_soft"
            android:paddingLeft="10dp"
            android:paddingTop="4dp"
            android:paddingRight="10dp"
            android:paddingBottom="4dp"
            android:text="@string/home_time_placeholder"
            android:textColor="@color/ui_title"
            android:textSize="20sp"
            android:textStyle="bold" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/layout_pet_switcher"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:elevation="20dp"
        android:orientation="vertical"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/layout_top_info">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="@dimen/home_nav_bar_height"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/tv_meta"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:background="@drawable/bg_home_info_chip_soft"
                android:ellipsize="end"
                android:maxLines="1"
                android:paddingLeft="10dp"
                android:paddingTop="4dp"
                android:paddingRight="10dp"
                android:paddingBottom="4dp"
                android:text="@string/home_meta_placeholder"
                android:textColor="@color/ui_title"
                android:textSize="14sp" />

            <TextView
                android:id="@+id/tv_current_pet_chip"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:background="@drawable/bg_home_recent_panel"
                android:ellipsize="end"
                android:maxEms="6"
                android:maxLines="1"
                android:paddingLeft="8dp"
                android:paddingTop="4dp"
                android:paddingRight="8dp"
                android:paddingBottom="4dp"
                android:text="@string/home_current_pet_none"
                android:textColor="@color/ui_title"
                android:textSize="11sp"
                android:textStyle="bold" />

            <ImageButton
                android:id="@+id/btn_pet_switch_expand"
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:layout_marginStart="6dp"
                android:background="@drawable/bg_home_side_circle"
                android:contentDescription="@string/home_cd_pet_switch_toggle"
                android:padding="5dp"
                android:src="@drawable/ic_settings"
                app:srcCompat="@drawable/ic_settings"
                app:tint="@null" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/layout_pet_switch_list"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone" />
    </LinearLayout>

    <TextView
        android:id="@+id/tv_date"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:layout_marginBottom="4dp"
        android:background="@drawable/bg_home_info_chip_soft"
        android:paddingLeft="10dp"
        android:paddingTop="4dp"
        android:paddingRight="10dp"
        android:paddingBottom="4dp"
        android:text="@string/home_date_placeholder"
        android:textColor="@color/ui_title"
        android:textSize="14sp"
        android:textStyle="bold"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/layout_pet_switcher" />

    <ImageView
        android:id="@+id/layout_content_slot"
        android:layout_width="0dp"
        android:layout_height="@dimen/home_content_height"
        android:contentDescription="@null"
        android:scaleType="centerCrop"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/tv_date" />

    <LinearLayout
        android:id="@+id/layout_top_reply_bubbles"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginBottom="8dp"
        android:clipChildren="true"
        android:clipToPadding="true"
        android:elevation="24dp"
        android:gravity="center_horizontal|bottom"
        android:orientation="vertical"
        android:paddingBottom="8dp"
        app:layout_constraintBottom_toTopOf="@+id/layout_bottom_nav"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <LinearLayout
        android:id="@+id/layout_side_actions"
        android:layout_width="@dimen/home_side_column_width"
        android:layout_height="wrap_content"
        android:elevation="24dp"
        android:gravity="center"
        android:orientation="vertical"
        app:layout_constraintBottom_toBottomOf="@+id/layout_content_slot"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="@+id/layout_content_slot">

        <ImageButton
            android:id="@+id/btn_affection"
            android:layout_width="@dimen/home_side_button_size"
            android:layout_height="@dimen/home_side_button_size"
            android:background="@drawable/bg_home_side_circle"
            android:contentDescription="@string/home_cd_affection"
            android:padding="12dp"
            android:scaleType="fitCenter"
            android:src="@drawable/ic_affection"
            app:srcCompat="@drawable/ic_affection"
            app:tint="@null" />

        <ImageButton
            android:id="@+id/btn_dress_up"
            android:layout_width="@dimen/home_side_button_size"
            android:layout_height="@dimen/home_side_button_size"
            android:layout_marginTop="16dp"
            android:background="@drawable/bg_home_side_circle"
            android:contentDescription="@string/home_cd_dress_up"
            android:padding="12dp"
            android:scaleType="fitCenter"
            android:src="@drawable/ic_outfit"
            app:srcCompat="@drawable/ic_outfit"
            app:tint="@null" />

        <ImageButton
            android:id="@+id/btn_logs"
            android:layout_width="@dimen/home_side_button_size"
            android:layout_height="@dimen/home_side_button_size"
            android:layout_marginTop="16dp"
            android:background="@drawable/bg_home_side_circle"
            android:contentDescription="@string/home_cd_logs"
            android:padding="12dp"
            android:scaleType="fitCenter"
            android:src="@drawable/ic_diary"
            app:srcCompat="@drawable/ic_diary"
            app:tint="@null" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/layout_bottom_nav"
        android:layout_width="0dp"
        android:layout_height="@dimen/home_menu_item_height"
        android:elevation="24dp"
        android:gravity="center"
        android:orientation="horizontal"
        app:layout_constraintBottom_toBottomOf="@+id/layout_content_slot"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <TextView
            android:id="@+id/nav_help"
            android:layout_width="0dp"
            android:layout_height="@dimen/home_menu_item_height"
            android:layout_marginEnd="@dimen/home_menu_item_gap"
            android:layout_weight="1"
            android:background="@drawable/bg_home_tab_item"
            android:drawablePadding="4dp"
            android:gravity="center"
            android:paddingLeft="4dp"
            android:paddingTop="8dp"
            android:paddingRight="4dp"
            android:paddingBottom="6dp"
            android:text="@string/home_nav_help"
            android:textAllCaps="false"
            android:textColor="@android:color/white"
            android:textSize="13sp"
            android:textStyle="bold"
            app:drawableTopCompat="@drawable/ic_nav_help_adaptive" />

        <TextView
            android:id="@+id/nav_feed"
            android:layout_width="0dp"
            android:layout_height="@dimen/home_menu_item_height"
            android:layout_marginEnd="@dimen/home_menu_item_gap"
            android:layout_weight="1"
            android:background="@drawable/bg_home_tab_item"
            android:drawablePadding="4dp"
            android:gravity="center"
            android:paddingLeft="4dp"
            android:paddingTop="8dp"
            android:paddingRight="4dp"
            android:paddingBottom="6dp"
            android:text="@string/home_nav_feed"
            android:textAllCaps="false"
            android:textColor="@android:color/white"
            android:textSize="13sp"
            android:textStyle="bold"
            app:drawableTopCompat="@drawable/ic_nav_feed_adaptive" />

        <TextView
            android:id="@+id/nav_store"
            android:layout_width="0dp"
            android:layout_height="@dimen/home_menu_item_height"
            android:layout_marginEnd="@dimen/home_menu_item_gap"
            android:layout_weight="1"
            android:background="@drawable/bg_home_tab_item"
            android:drawablePadding="4dp"
            android:gravity="center"
            android:paddingLeft="4dp"
            android:paddingTop="8dp"
            android:paddingRight="4dp"
            android:paddingBottom="6dp"
            android:text="@string/home_nav_store"
            android:textAllCaps="false"
            android:textColor="@android:color/white"
            android:textSize="13sp"
            android:textStyle="bold"
            app:drawableTopCompat="@drawable/ic_nav_store_adaptive" />

        <TextView
            android:id="@+id/nav_outing"
            android:layout_width="0dp"
            android:layout_height="@dimen/home_menu_item_height"
            android:layout_marginEnd="@dimen/home_menu_item_gap"
            android:layout_weight="1"
            android:background="@drawable/bg_home_tab_item"
            android:drawablePadding="4dp"
            android:gravity="center"
            android:paddingLeft="4dp"
            android:paddingTop="8dp"
            android:paddingRight="4dp"
            android:paddingBottom="6dp"
            android:text="@string/home_nav_outing"
            android:textAllCaps="false"
            android:textColor="@android:color/white"
            android:textSize="13sp"
            android:textStyle="bold"
            app:drawableTopCompat="@drawable/ic_nav_outing_adaptive" />

        <TextView
            android:id="@+id/nav_settings"
            android:layout_width="0dp"
            android:layout_height="@dimen/home_menu_item_height"
            android:layout_weight="1"
            android:background="@drawable/bg_home_tab_item"
            android:drawablePadding="4dp"
            android:gravity="center"
            android:paddingLeft="4dp"
            android:paddingTop="8dp"
            android:paddingRight="4dp"
            android:paddingBottom="6dp"
            android:text="@string/home_nav_settings"
            android:textAllCaps="false"
            android:textColor="@android:color/white"
            android:textSize="13sp"
            android:textStyle="bold"
            app:drawableTopCompat="@drawable/ic_nav_settings_adaptive" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/layout_chat_input"
        android:layout_width="0dp"
        android:layout_height="@dimen/home_operate_height"
        android:background="@drawable/bg_home_chat_input_transparent"
        android:elevation="30dp"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingLeft="8dp"
        android:paddingRight="8dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/layout_content_slot">

        <ImageButton
            android:id="@+id/btn_recent_toggle"
            android:layout_width="@dimen/home_chat_action_size"
            android:layout_height="@dimen/home_chat_action_size"
            android:background="@drawable/bg_home_side_circle"
            android:contentDescription="@string/home_cd_recent_toggle"
            android:padding="10dp"
            android:scaleType="fitCenter"
            android:src="@drawable/ic_chat"
            app:srcCompat="@drawable/ic_chat"
            app:tint="@null" />

        <EditText
            android:id="@+id/et_home_input"
            android:layout_width="0dp"
            android:layout_height="@dimen/home_input_height"
            android:layout_marginStart="8dp"
            android:layout_marginEnd="8dp"
            android:layout_weight="1"
            android:autofillHints="message"
            android:background="@drawable/bg_home_input_field"
            android:focusable="true"
            android:focusableInTouchMode="true"
            android:hint="@string/home_hint_chat_input"
            android:imeOptions="actionSend"
            android:inputType="textCapSentences|textMultiLine"
            android:maxLines="3"
            android:minLines="1"
            android:paddingLeft="12dp"
            android:paddingRight="12dp"
            android:textColor="@color/text_primary"
            android:textColorHint="@color/text_hint" />

        <ImageButton
            android:id="@+id/btn_home_send"
            android:layout_width="@dimen/home_chat_action_size"
            android:layout_height="@dimen/home_chat_action_size"
            android:background="@drawable/bg_home_send_circle"
            android:contentDescription="@string/home_cd_send"
            android:padding="10dp"
            android:scaleType="fitCenter"
            android:src="@drawable/ic_send"
            app:srcCompat="@drawable/ic_send"
            app:tint="@null" />
    </LinearLayout>

    <View
        android:id="@+id/layout_down_bar"
        android:layout_width="0dp"
        android:layout_height="@dimen/home_down_height"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/layout_chat_input" />

    <LinearLayout
        android:id="@+id/layout_recent_chat_panel"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginBottom="6dp"
        android:background="@drawable/bg_home_recent_panel"
        android:elevation="28dp"
        android:orientation="vertical"
        android:padding="10dp"
        android:visibility="gone"
        app:layout_constraintBottom_toTopOf="@+id/layout_chat_input"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="@+id/layout_content_slot">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/home_recent_title"
                android:textColor="@color/ui_title"
                android:textSize="14sp"
                android:textStyle="bold" />

            <ImageButton
                android:id="@+id/btn_recent_fullscreen"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:background="@drawable/bg_home_side_circle"
                android:contentDescription="@string/home_cd_recent_fullscreen"
                android:padding="8dp"
                android:src="@drawable/ic_expand_outward"
                app:srcCompat="@drawable/ic_expand_outward"
                app:tint="@null" />
        </LinearLayout>

        <ScrollView
            android:id="@+id/sv_recent_chat"
            android:layout_width="match_parent"
            android:layout_height="150dp"
            android:layout_marginTop="6dp"
            android:fillViewport="true"
            android:scrollbars="vertical">

            <LinearLayout
                android:id="@+id/layout_recent_bubbles"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingBottom="2dp" />
        </ScrollView>
    </LinearLayout>

    <FrameLayout
        android:id="@+id/layout_recent_fullscreen"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:background="#A6000000"
        android:clickable="true"
        android:elevation="40dp"
        android:focusable="true"
        android:padding="12dp"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@drawable/bg_home_recent_panel"
            android:orientation="vertical"
            android:padding="12dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/home_recent_fullscreen_title"
                    android:textColor="@color/ui_title"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <ImageButton
                    android:id="@+id/btn_recent_fullscreen_close"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:background="@drawable/bg_home_side_circle"
                    android:contentDescription="@string/home_cd_recent_close"
                    android:padding="9dp"
                    android:src="@drawable/ic_collapse_inward"
                    app:srcCompat="@drawable/ic_collapse_inward"
                    app:tint="@null" />
            </LinearLayout>

            <ScrollView
                android:id="@+id/sv_recent_chat_fullscreen"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_marginTop="8dp"
                android:layout_weight="1"
                android:fillViewport="true"
                android:scrollbars="vertical">

                <LinearLayout
                    android:id="@+id/layout_recent_bubbles_full"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:paddingBottom="6dp" />
            </ScrollView>
        </LinearLayout>
    </FrameLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
